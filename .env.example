# =============================================================================
# Personal Onboarding Assistant — environment template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- LLM provider ------------------------------------------------------------
# LLM_PROVIDER: "openai" or "anthropic"
LLM_PROVIDER=openai
# LLM_MODEL: e.g. gpt-4o-mini, gpt-4o, claude-3-5-sonnet-latest
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Slack (Phase 4 bot interface) -------------------------------------------
# SLACK_BOT_TOKEN: xoxb-... (bot token)
SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN: xapp-... (app-level token, Socket Mode)
SLACK_APP_TOKEN=
# SLACK_USER_TOKEN: xoxp-... (user token, needed for search.messages)
SLACK_USER_TOKEN=

# --- Pilot team scoping (Phase 3) --------------------------------------------
# Human-readable pilot team name
PILOT_TEAM_NAME=
# The team's help channel id, e.g. C0123456789
SLACK_HELP_CHANNEL_ID=

# --- Confluence (Phase 3, Tool 3) --------------------------------------------
# Base URL, e.g. https://confluence.eng.nutanix.com
CONFLUENCE_BASE_URL=
# Pilot team's Confluence space key
CONFLUENCE_SPACE_KEY=
# API token / PAT
CONFLUENCE_API_TOKEN=
# Email/username (if using basic auth)
CONFLUENCE_USERNAME=
