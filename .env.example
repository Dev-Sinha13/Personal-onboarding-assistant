# =============================================================================
# Personal Onboarding Assistant — environment template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- LLM provider ------------------------------------------------------------
# NAI Gateway is unavailable for the intern hackathon (GPU shortage), so the
# default is a LOCAL model via Ollama (OpenAI-compatible endpoint).
# LLM_PROVIDER: "ollama" | "openai" | "anthropic"
LLM_PROVIDER=ollama
# LLM_MODEL: MUST support tool-calling. Recommended for 16GB M1 Pro: qwen2.5:7b
# (alternatives: llama3.1:8b, mistral:7b). Plain "llama3" has NO tool support.
# OpenAI fallback: gpt-4o-mini.
LLM_MODEL=qwen2.5:7b
# Ollama endpoint (run `ollama serve`; pull a model with `ollama pull llama3`)
OLLAMA_BASE_URL=http://localhost:11434
# Only needed if you switch LLM_PROVIDER to a hosted provider:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Slack (Phases 3 & 4 bot interface) --------------------------------------
# Create/test the app in the sandbox workspace first: nutanixtest.slack.com
# Scopes: chat:write, app_mentions:read, im:history, channels:history
# NOTE: search.messages / search:read is PROHIBITED at Nutanix. Use
# conversations.history on the specific help channel instead.
SLACK_BOT_TOKEN=
# App-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# --- Pilot team scoping (Nutanix IAM team) -----------------------------------
PILOT_TEAM_NAME=Nutanix IAM Team
# Help channel name (for readability) and id (fill C... from the channel)
SLACK_HELP_CHANNEL_NAME=#iam-help
SLACK_HELP_CHANNEL_ID=

# --- Confluence (Phase 3, Tool 3) --------------------------------------------
CONFLUENCE_BASE_URL=https://confluence.eng.nutanix.com:8443
# Comma-separated space keys used in CQL: space in ("IAM20","PRIS")
CONFLUENCE_SPACE_KEYS=IAM20,PRIS
# Personal API token / PAT
CONFLUENCE_API_TOKEN=
# Email/username (if using basic auth)
CONFLUENCE_USERNAME=
